{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "outDir": ".",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["electron/main.ts", "electron/preload.ts", "electron/agent-tools.ts", "lib/mind-palace/sqlite-storage.ts", "lib/mind-palace/vector-index.ts", "lib/mind-palace/types.ts", "lib/mind-palace/storage-interface.ts", "lib/mind-palace/sql.js.d.ts"],
  "exclude": ["node_modules", "dist"]
}
